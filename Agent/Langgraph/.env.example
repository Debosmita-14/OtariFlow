# OtariFlow environment variables
# Copy this file to .env and fill in your values.

TOTAL_BUDGET=5.00
BUDGET_WARNING_THRESHOLD=0.80
RISK_BLOCK_THRESHOLD=0.75
BACKEND_PORT=8000

# ─── LLM Provider API Key ───
# xAI Grok — provides grok-4.1-fast, grok-4.3, grok-4.20 models.
# Sign up at https://console.x.ai and create an API key.
XAI_API_KEY=your_xai_api_key_here

# Optional: timeout in ms before the latency watchdog triggers escalation
MODEL_TIMEOUT_MS=9000

# Legacy key (kept for backward compatibility, not used for LLM calls)
OTARI_API_KEY=your_api_key_here
